generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum AssetCondition {
  usable
  for_repair
  for_disposal
}

enum OwnershipType {
  company
  personal
}

enum MovementType {
  assignment
  transfer
  site_transfer
  resignation
  new_hire
  repair_send
  repair_return
  disposal
}

enum AssignmentStatus {
  active
  returned
  transferred
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model SystemUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Organization ─────────────────────────────────────────────────────────────

model Site {
  id          String       @id @default(cuid())
  name        String
  address     String?
  createdAt   DateTime     @default(now())
  departments Department[]
  employees   Employee[]
  assets      Asset[]
}

model Department {
  id        String     @id @default(cuid())
  name      String
  siteId    String
  createdAt DateTime   @default(now())
  site      Site       @relation(fields: [siteId], references: [id])
  employees Employee[]
}

model Category {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  assets    Asset[]
}

// ─── People ───────────────────────────────────────────────────────────────────

model Employee {
  id           String   @id @default(cuid())
  name         String
  email        String?  @unique
  phone        String?
  employeeId   String?  @unique
  siteId       String?
  departmentId String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  site         Site?             @relation(fields: [siteId], references: [id])
  department   Department?       @relation(fields: [departmentId], references: [id])
  assignments  AssetAssignment[]
  movementLogs MovementLog[]
}

// ─── Assets ───────────────────────────────────────────────────────────────────

model Asset {
  id           String         @id @default(cuid())
  name         String
  serialNumber String?        @unique
  categoryId   String?
  siteId       String?
  condition    AssetCondition @default(usable)
  ownership    OwnershipType  @default(company)
  description  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  category     Category?         @relation(fields: [categoryId], references: [id])
  site         Site?             @relation(fields: [siteId], references: [id])
  assignments  AssetAssignment[]
  movementLogs MovementLog[]
}

model AssetAssignment {
  id         String           @id @default(cuid())
  assetId    String
  employeeId String
  status     AssignmentStatus @default(active)
  assignedAt DateTime         @default(now())
  returnedAt DateTime?
  notes      String?

  asset    Asset    @relation(fields: [assetId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
}

model MovementLog {
  id         String       @id @default(cuid())
  assetId    String
  employeeId String?
  type       MovementType
  notes      String?
  createdAt  DateTime     @default(now())

  asset    Asset     @relation(fields: [assetId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])
}
